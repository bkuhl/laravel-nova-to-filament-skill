{
    "name": "bkuhl/laravel-nova-to-filament-skill",
    "description": "A Claude AI skill (system prompt) that guides an AI coding agent through a complete, production-quality migration from Laravel Nova to Filament PHP v5.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "nova",
        "filament",
        "migration",
        "ai",
        "skill",
        "claude"
    ],
    "authors": [
        {
            "name": "Brian Kuhl",
            "homepage": "https://github.com/bkuhl"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Bkuhl\\LaravelNovaToFilamentSkill\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bkuhl\\LaravelNovaToFilamentSkill\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bkuhl\\LaravelNovaToFilamentSkill\\LaravelNovaToFilamentSkillServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
